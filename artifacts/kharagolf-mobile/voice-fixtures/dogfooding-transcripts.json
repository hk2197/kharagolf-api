    { "id": "d134", "transcript": "make it a par instead",       "expected": { "kind": "relative", "hole": null, "delta": 0,    "correction": true } },

    { "_comment": "── Hole-targeted corrections (\"change hole 7 to a five\", \"hole 12 should be a bogey\", \"fix hole 9 to 4\"). Players notice a misspoken score one or two holes later and call out the older hole by name. The parser carries the explicit hole AND `correction: true` so the call site replaces the existing entry on that hole rather than appending a new one. ──", "_groupKey": "holeTargetedCorrectionDigit",
      "id": "d135", "transcript": "change hole 7 to a five",     "expected": { "kind": "score",    "hole": 7,    "strokes": 5,  "correction": true } },
    { "id": "d136", "transcript": "hole 12 should be a bogey",   "expected": { "kind": "relative", "hole": 12,   "delta": 1,    "correction": true } },
    { "id": "d137", "transcript": "fix hole 9 to 4",             "expected": { "kind": "score",    "hole": 9,    "strokes": 4,  "correction": true } },
    { "id": "d138", "transcript": "change hole 3 to a birdie",   "expected": { "kind": "relative", "hole": 3,    "delta": -1,   "correction": true } },
    { "id": "d139", "transcript": "hole 15 should be a par",     "expected": { "kind": "relative", "hole": 15,   "delta": 0,    "correction": true } },
    { "id": "d140", "transcript": "fix hole 11 to a bogey",      "expected": { "kind": "relative", "hole": 11,   "delta": 1,    "correction": true } },

    { "_comment": "── Hole-targeted corrections where the hole number is spoken as a word (\"change hole seven to a five\", \"hole twelve should be a bogey\"). Dogfooders use the worded form interchangeably with digits, so the parser has to recognise both. The known hole-number mishears (\"tin\" -> 10, \"leaven\"/\"elven\" -> 11) are accepted alongside the standard \"one\"–\"eighteen\" words. ──", "_groupKey": "holeTargetedCorrectionWord",
      "id": "d141", "transcript": "change hole seven to a five",  "expected": { "kind": "score",    "hole": 7,    "strokes": 5,  "correction": true } },
    { "id": "d142", "transcript": "hole twelve should be a bogey", "expected": { "kind": "relative", "hole": 12,   "delta": 1,    "correction": true } },
    { "id": "d143", "transcript": "fix hole eleven to four",     "expected": { "kind": "score",    "hole": 11,   "strokes": 4,  "correction": true } },
    { "id": "d144", "transcript": "change hole nine to a birdie", "expected": { "kind": "relative", "hole": 9,    "delta": -1,   "correction": true } },
    { "id": "d145", "transcript": "hole eighteen should be a par", "expected": { "kind": "relative", "hole": 18,   "delta": 0,    "correction": true } },
    { "id": "d146", "transcript": "fix hole tin to a bogey",     "expected": { "kind": "relative", "hole": 10,   "delta": 1,    "correction": true } },

    { "_comment": "── Worded hole numbers in everyday (non-correction) utterances. The general hole-detection helper (`extractHole`) used by every regular utterance now accepts the same word forms the correction branch already accepts (\"one\"–\"eighteen\" plus the \"tin\"/\"leaven\"/\"elven\" mishears), so players who say \"birdie on seven\", \"log par on twelve\" or \"took eight on hole eleven\" no longer lose the hole number. The matched \"hole N\" / \"on N\" reference is also erased before the spelled-out 11–15 stroke rule and the catch-all absolute number rule run, so a worded hole like \"eleven\" isn't double-counted as a stroke total. ──",
      "id": "d147", "transcript": "birdie on seven",             "expected": { "kind": "relative", "hole": 7,    "delta": -1 } },
    { "id": "d148", "transcript": "log par on twelve",           "expected": { "kind": "relative", "hole": 12,   "delta": 0  } },
    { "id": "d149", "transcript": "took eight on hole eleven",   "expected": { "kind": "score",    "hole": 11,   "strokes": 8 } }
  ]
