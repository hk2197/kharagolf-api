{
    "name": "@workspace/api-server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
          "dev": "export NODE_ENV=development && (fuser -k ${PORT}/tcp 2>/dev/null || true) && pnpm run build && pnpm run start",
          "prebuild": "node ../../scripts/check-sql-array-anti-patterns.mjs && bash ../../scripts/apply-prod-migrations.sh && bash ../../scripts/predeploy-db-drift.sh && bash ../../scripts/run-prod-backfills.sh",
          "build": "node ./build.mjs",
          "start": "node --enable-source-maps ./dist/index.mjs",
          "start:api-only": "node --enable-source-maps ./dist/index.mjs",
          "worker:dev": "export NODE_ENV=development && pnpm run build && pnpm run worker:start",
          "worker:start": "node --enable-source-maps ./dist/highlightWorker.mjs",
          "swing-fps-worker:start": "node --enable-source-maps ./dist/swingFpsProbeWorker.mjs",
          "typecheck": "tsc -p tsconfig.json --noEmit",
          "pretest": "bash ../../scripts/apply-test-schema.sh",
          "test": "vitest run --config vitest.config.ts",
          "test:e2e": "playwright test --config e2e/playwright.config.ts",
          "test:a11y": "playwright test --config e2e/playwright.config.ts e2e/a11y-top20.spec.ts",
          "backfill:privacy-prefs": "tsx scripts/backfillPrivacyCommPrefs.ts",
          "backfill:media-durations": "tsx scripts/backfillMediaDurations.ts",
          "backfill:swing-video-fps": "tsx scripts/backfillSwingVideoFps.ts",
          "backfill:round-weather-cache": "tsx scripts/backfillRoundWeatherCache.ts",
          "backfill:caddie-rec-weather": "tsx scripts/backfillCaddieRecWeather.ts",
          "backfill:social-links": "tsx scripts/backfillSocialLinks.ts",
          "backfill:course-map-defaults": "tsx scripts/backfillCourseMapDefaults.ts",
          "backfill:manual-entry-alert-recipients": "tsx scripts/backfillManualEntryAlertRecipients.ts",
          "backfill:manual-entry-alert-skip-reasons": "tsx scripts/backfillManualEntryAlertSkipReasons.ts",
          "backfill:coach-payout-change-audit": "tsx scripts/backfillCoachPayoutChangeAudit.ts"
    },
    "dependencies": {
          "@google-cloud/storage": "^7.19.0",
          "@resvg/resvg-js": "^2.6.2",
          "@types/archiver": "^7.0.0",
          "@types/pdfkit": "^0.17.5",
          "@types/qrcode": "^1.5.6",
          "@workspace/api-zod": "workspace:*",
          "@workspace/coach-payout-labels": "workspace:*",
          "@workspace/member-admin-roles": "workspace:*",
          "@workspace/course-map-defaults": "workspace:*",
          "@workspace/db": "workspace:*",
          "@workspace/golf-physics": "workspace:*",
          "@workspace/integrations-openai-ai-server": "workspace:*",
          "archiver": "^7.0.1",
          "bcryptjs": "^3.0.3",
          "bwip-js": "^4.9.0",
          "connect-pg-simple": "^10.0.0",
          "cookie-parser": "^1.4.7",
          "cors": "^2",
          "drizzle-orm": "catalog:",
          "express": "^5",
          "express-session": "^1.19.0",
          "google-auth-library": "^10.6.2",
          "jose": "^6.2.2",
          "nodemailer": "^8.0.4",
          "openid-client": "^6.8.2",
          "pdfkit": "^0.18.0",
          "pino": "^9",
          "pino-http": "^10",
          "qrcode": "^1.5.4",
          "razorpay": "^2.9.6",
          "ws": "^8.20.0"
    },
    "devDependencies": {
          "@axe-core/playwright": "^4.11.2",
          "@playwright/test": "^1.59.1",
          "@types/adm-zip": "^0.5.8",
          "@types/bcryptjs": "^3.0.0",
          "@types/cookie-parser": "^1.4.10",
          "@types/cors": "^2.8.19",
          "@types/express": "^5.0.6",
          "@types/node": "catalog:",
          "@types/nodemailer": "^7.0.11",
          "@types/pg": "^8.18.0",
          "@types/supertest": "^7.2.0",
          "@types/ws": "^8.18.1",
          "adm-zip": "^0.5.17",
          "esbuild": "^0.27.3",
          "esbuild-plugin-pino": "^2.3.3",
          "pdf-parse": "1.1.1",
          "pg": "^8.20.0",
          "pino-pretty": "^13",
          "supertest": "^7.2.2",
          "thread-stream": "3.1.0",
          "tsx": "catalog:",
          "vitest": "^4.1.2"
    }
}
