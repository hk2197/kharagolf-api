# Ignore node_modules
**/node_modules/**

# Ignore build artifacts
**/dist/**
**/build/**
**/.next/**
**/.cache/**
**/out/**

# Ignore lock files
pnpm-lock.yaml
package-lock.json
yarn.lock

# Ignore environment variables
.env
.env.*

# Ignore logs
*.log

# Ignore git
.git/

# Ignore large data/assets
**/*.mp4
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.pdf

# Specific to this project: ignore translation baselines and large JSONs
scripts/*-baseline.json
lib/**/translations/*.json
